# =============================================================================
# TenderClaw Environment Configuration
# Copy to .env and fill in your values
# =============================================================================

# Server
TENDERCLAW_HOST=0.0.0.0
TENDERCLAW_PORT=6669
TENDERCLAW_DEV=1

# AI Provider API Keys (add the ones you use)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=...
XAI_API_KEY=...
DEEPSEEK_API_KEY=...
OPENROUTER_API_KEY=...
# Local providers
TENDERCLAW_LMSTUDIO_BASE_URL=http://localhost:1234/v1
# TENDERCLAW_OLLAMA_BASE_URL=http://localhost:11434/v1



# Logging
TENDERCLAW_LOG_LEVEL=INFO
